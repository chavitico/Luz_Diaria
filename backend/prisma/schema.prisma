generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Devotional {
  id                    String   @id @default(cuid())
  date                  String   @unique // YYYY-MM-DD format

  // English content
  title                 String
  bibleVerse            String
  bibleReference        String
  reflection            String
  story                 String
  biblicalCharacter     String
  application           String
  prayer                String
  topic                 String

  // Spanish content
  titleEs               String
  bibleVerseEs          String
  bibleReferenceEs      String   @default("")
  reflectionEs          String
  storyEs               String
  biblicalCharacterEs   String
  applicationEs         String
  prayerEs              String
  topicEs               String

  // Image
  imageUrl              String

  // Metadata
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ============================================
// GAMIFICATION SYSTEM MODELS
// ============================================

model User {
  id                    String   @id @default(cuid())
  nickname              String   @unique
  nicknameLower         String   @unique // For case-insensitive uniqueness
  avatarId              String   @default("avatar_dove")
  frameId               String?  // Selected avatar frame
  titleId               String?  // Selected spiritual title
  themeId               String   @default("theme_amanecer")
  selectedMusicId       String   @default("music_free_1")
  points                Int      @default(0)
  streakCurrent         Int      @default(0)
  streakBest            Int      @default(0)
  devotionalsCompleted  Int      @default(0)
  totalTimeSeconds      Int      @default(0)
  lastActiveAt          DateTime?

  // Daily action tracking (JSON field for simplicity)
  dailyActions          String   @default("{}")  // JSON: {shareDate, shareCount, prayerDate, prayerDone, ttsDate, ttsDone}

  // Device and migration tracking
  deviceId              String?  // Optional stable device identifier
  migratedFromUserId    String?  // Track account migrations

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  inventory             UserInventory[]
  weeklyProgress        WeeklyProgress[]
  favorites             UserFavorite[]
  pointLedger           PointLedger[]
  transferCodesGenerated TransferCode[] @relation("TransferCodeSource")
}

model StoreItem {
  id            String   @id @default(cuid())
  type          String   // theme, frame, music, title, avatar
  nameEn        String
  nameEs        String
  descriptionEn String   @default("")
  descriptionEs String   @default("")
  pricePoints   Int
  assetRef      String   @default("") // Reference to asset file/color
  rarity        String   @default("common") // common, rare, epic
  sortOrder     Int      @default(0)
  available     Boolean  @default(true)

  // For themes: JSON with color palette
  metadata      String   @default("{}")

  createdAt     DateTime @default(now())

  inventory     UserInventory[]
}

model UserInventory {
  id          String   @id @default(cuid())
  userId      String
  itemId      String
  acquiredAt  DateTime @default(now())
  source      String   @default("store") // store, challenge, milestone, free

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  item        StoreItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

model WeeklyChallenge {
  id              String   @id @default(cuid())
  weekId          String   // Format: "2026-W06" (ISO week)
  challengeIndex  Int      // 0 or 1 for the week

  type            String   // devotional_complete, share, prayer
  goalCount       Int
  rewardPoints    Int
  rewardItemId    String?  // Optional item reward

  titleEn         String
  titleEs         String
  descriptionEn   String
  descriptionEs   String

  startDate       DateTime
  endDate         DateTime

  createdAt       DateTime @default(now())

  progress        WeeklyProgress[]

  @@unique([weekId, challengeIndex])
}

model WeeklyProgress {
  id            String   @id @default(cuid())
  userId        String
  challengeId   String

  currentCount  Int      @default(0)
  completed     Boolean  @default(false)
  claimed       Boolean  @default(false)

  updatedAt     DateTime @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge     WeeklyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
}

model UserFavorite {
  id              String   @id @default(cuid())
  userId          String
  devotionalDate  String   // YYYY-MM-DD
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, devotionalDate])
}

// ============================================
// BIBLE PASSAGE CACHE
// ============================================

model BiblePassage {
  id                String   @id @default(cuid())
  refKey            String   // Normalized key: "lucas_10_25-37", "juan_3_16"
  lang              String   // "es" or "en"

  book              String   // "Lucas", "Luke"
  chapterStart      Int
  verseStart        Int
  chapterEnd        Int?     // For ranges
  verseEnd          Int?     // For ranges

  referenceDisplay  String   // "Lucas 10:25-37" (human readable)
  text              String   // Full passage text

  source            String   @default("api") // "api" or "manual"
  createdAt         DateTime @default(now())

  @@unique([refKey, lang])
  @@index([lang])
}

// ============================================
// POINTS LEDGER - Idempotent Point Tracking
// ============================================

model PointLedger {
  id          String   @id @default(cuid())
  userId      String
  ledgerId    String   // Deterministic ID like "devotional_2026-02-14"
  type        String   // devotional_complete, streak_bonus, share, prayer, tts, challenge_reward
  dateId      String   // Date for the action (YYYY-MM-DD)
  amount      Int
  metadata    String   @default("{}")  // JSON for extra data
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ledgerId])
  @@index([userId])
}

// ============================================
// TRANSFER CODES - Cross-device Restore
// ============================================

model TransferCode {
  id            String    @id @default(cuid())
  code          String    @unique
  sourceUserId  String
  expiresAt     DateTime
  used          Boolean   @default(false)
  usedByUserId  String?
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  sourceUser    User      @relation("TransferCodeSource", fields: [sourceUserId], references: [id], onDelete: Cascade)
}
