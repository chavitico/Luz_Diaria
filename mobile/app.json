{
  "expo": {
    "name": "Luz Diaria",
    "slug": "luz-diaria",
    "scheme": "vibecode",
    "version": "1.0.14",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.luzdiaria.app",
      "buildNumber": "13",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Luz Diaria uses the microphone to record audio tracks that the app attaches to your creations.",
        "NSSpeechRecognitionUsageDescription": "Luz Diaria uses speech recognition to turn your spoken words into text inside the app.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.luzdiaria.app",
      "versionCode": 13,
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "icon": "./icon.png"
  }
}
